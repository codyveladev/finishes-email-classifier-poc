# Copy to .env and fill in real values. .env is gitignored.

# Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# Bearer token for POST /api/classify — pick a long random string.
# Any request without this exact token in Authorization: Bearer <...> is rejected.
API_TOKEN=change_me_to_a_long_random_string
